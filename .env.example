# 复制本文件为 .env 并填写真实值，切勿将 .env 提交到版本控制。

# ── Qwen-VL API 配置 ─────────────────────────────────────────────────────────
# 必填：通义千问 API Key
QWEN_API_KEY=your_api_key_here

# API 基础地址（可选，默认阿里云 DashScope）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型名称（可选）
QWEN_MODEL=qwen3.5-omni-flash

# 单次请求最大输出 token 数（可选）
QWEN_MAX_TOKENS=1024

# Qwen API 请求超时秒数（可选，0=使用库默认值）
QWEN_TIMEOUT=120.0

# 瞬时错误最大重试次数（可选）
QWEN_MAX_RETRIES=2

# ── 服务鉴权 ─────────────────────────────────────────────────────────────────
# 不设置或留空 → 鉴权禁用（适合本地开发）
# 设置后，所有 /v1/* 请求必须携带 X-API-Key: <值> 请求头
SERVICE_API_KEY=

# ── 输入限制 ─────────────────────────────────────────────────────────────────
# Base64 字符串最大长度（默认 ~20 MB，对应约 15 MB 原图）
MAX_IMAGE_B64_CHARS=20971520

# 图像最大像素数（默认 4096×4096）
MAX_IMAGE_PIXELS=16777216
